# Base URL delle API esposte dal server Express (se cambi host/porta aggiorna questo valore con il suffisso /api)
VITE_API_BASE_URL=http://localhost:3333/api

# Identificativo utente da inviare nelle richieste (facoltativo)
VITE_API_USER=replace-with-your-user

# Ruoli inviati come header X-Roles.
# NOTA autorizzazione: il server li onora SOLO in "open mode" senza Basic Auth e
# solo se il backend ha TRUST_CLIENT_ROLE_HEADERS=1 (sviluppo locale). Con Basic
# Auth attivo i ruoli arrivano dal server (APP_AUTH_ROLES) e questo header viene
# ignorato (la dashboard same-origin si autentica via prompt Basic del browser).
# In ambienti condivisi rimuovi questo valore o limitalo a sola-lettura.
VITE_API_ROLES=admin
