{
  "name": "game-server",
  "private": true,
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5",
    "ajv": "^8.18.0",
    "cors": "^2",
    "csv-parse": "^5",
    "express": "^4",
    "fast-glob": "^3",
    "gray-matter": "^4",
    "js-yaml": "^4"
  },
  "devDependencies": {
    "prisma": "^5"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "dev": "node index.js",
    "dashboard:build": "npm --prefix ../apps/dashboard run build",
    "dev:setup": "prisma generate && prisma migrate deploy && prisma db seed && node scripts/backfill-v1-snapshots.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed",
    "audit:slug": "node ./scripts/audit-slug.js",
    "schema:doc": "node ./scripts/generate-schema-doc.js",
    "schema:doc:check": "node ./scripts/generate-schema-doc.js --check",
    "prisma:studio": "prisma studio",
    "start:lan": "node scripts/start-lan.js",
    "test": "node ./test/run-tests.js",
    "evo:import": "node scripts/evo-import.js"
  }
}
