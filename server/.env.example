# URL di connessione al database Postgres usato da Prisma
# - se il server gira in locale contro il container Postgres esposto da Docker, usa localhost:5433
#   (porta host 5433 per evitare conflitto con il repo Game che usa 5432)
# - se il server gira dentro il servizio `server` di docker-compose, usa host `db` (es: postgresql://postgres:postgres@db:5432/game?schema=public)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/game?schema=public"

# Porta su cui esporre il server Express (opzionale)
PORT=3333

# Ruoli autorizzati per le mutazioni della tassonomia (lista separata da virgole, opzionale)
# TAXONOMY_WRITE_ROLES="taxonomy:write,admin"

# Host su cui esporre il server (localhost per uso locale, 0.0.0.0 per accesso LAN)
# HOST=localhost

# Se impostato a 1, Express serve anche il build statico della dashboard sullo stesso URL
# SERVE_DASHBOARD=0

# Credenziali minime per proteggere l'app in modalitÃ  LAN con Basic Auth
# APP_AUTH_USER=admin
# APP_AUTH_PASSWORD=change-me
# APP_AUTH_ROLES=taxonomy:write,admin

# --- Integrazione con repo Game ---
# Questo server espone GET /api/traits/glossary consumato dal backend Game
# quando GAME_DATABASE_ENABLED=true sul lato Game.
# Nessuna configurazione necessaria qui — l'endpoint è sempre disponibile.
