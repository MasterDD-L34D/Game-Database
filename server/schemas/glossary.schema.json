{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "glossary.schema.json",
  "$comment": "Canonical source: Game/packages/contracts/schemas/glossary.schema.json",
  "title": "TraitGlossaryResponse",
  "description": "Response shape for GET /api/traits/glossary (Game-Database -> Game integration)",
  "type": "object",
  "required": ["traits"],
  "properties": {
    "traits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["_id", "labels"],
        "properties": {
          "_id": { "type": "string", "description": "Trait slug identifier" },
          "labels": {
            "type": "object",
            "properties": {
              "it": { "type": "string" },
              "en": { "type": "string" }
            }
          },
          "descriptions": {
            "type": "object",
            "properties": {
              "it": { "type": ["string", "null"] },
              "en": { "type": ["string", "null"] }
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
